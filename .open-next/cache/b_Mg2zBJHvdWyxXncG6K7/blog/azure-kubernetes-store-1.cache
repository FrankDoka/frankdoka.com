ue\" style=\"border-top-left-radius:40px;border-top-right-radius:40px\"><div class=\"relative isolate flex w-full flex-col pt-9\"><a href=\"#main-content\" class=\"sr-only focus:not-sr-only focus:absolute focus:z-50 focus:m-4 focus:rounded-lg focus:bg-[var(--theme-text-primary)] focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-[var(--theme-bg-page)]\">Skip to main content</a><svg aria-hidden=\"true\" class=\"absolute inset-x-0 -top-14 -z-10 h-[1000px] w-full [mask-image:linear-gradient(to_bottom_left,white_40%,transparent_50%)] fill-[var(--theme-bg-elevated)] stroke-[var(--theme-border-subtle)]\"><rect width=\"100%\" height=\"100%\" fill=\"url(#_R_aldb_)\" stroke-width=\"0\"></rect><svg x=\"50%\" y=\"-96\" stroke-width=\"0\" class=\"overflow-visible\"><path transform=\"translate(64 160)\" d=\"M45.119 4.5a11.5 11.5 0 0 0-11.277 9.245l-25.6 128C6.82 148.861 12.262 155.5 19.52 155.5h63.366a11.5 11.5 0 0 0 11.277-9.245l25.6-128c1.423-7.116-4.02-13.755-11.277-13.755H45.119Z\"></path><path transform=\"translate(128 320)\" d=\"M45.119 4.5a11.5 11.5 0 0 0-11.277 9.245l-25.6 128C6.82 148.861 12.262 155.5 19.52 155.5h63.366a11.5 11.5 0 0 0 11.277-9.245l25.6-128c1.423-7.116-4.02-13.755-11.277-13.755H45.119Z\"></path><path transform=\"translate(288 480)\" d=\"M45.119 4.5a11.5 11.5 0 0 0-11.277 9.245l-25.6 128C6.82 148.861 12.262 155.5 19.52 155.5h63.366a11.5 11.5 0 0 0 11.277-9.245l25.6-128c1.423-7.116-4.02-13.755-11.277-13.755H45.119Z\"></path><path transform=\"translate(512 320)\" d=\"M45.119 4.5a11.5 11.5 0 0 0-11.277 9.245l-25.6 128C6.82 148.861 12.262 155.5 19.52 155.5h63.366a11.5 11.5 0 0 0 11.277-9.245l25.6-128c1.423-7.116-4.02-13.755-11.277-13.755H45.119Z\"></path><path transform=\"translate(544 640)\" d=\"M45.119 4.5a11.5 11.5 0 0 0-11.277 9.245l-25.6 128C6.82 148.861 12.262 155.5 19.52 155.5h63.366a11.5 11.5 0 0 0 11.277-9.245l25.6-128c1.423-7.116-4.02-13.755-11.277-13.755H45.119Z\"></path><path transform=\"translate(320 800)\" d=\"M45.119 4.5a11.5 11.5 0 0 0-11.277 9.245l-25.6 128C6.82 148.861 12.262 155.5 19.52 155.5h63.366a11.5 11.5 0 0 0 11.277-9.245l25.6-128c1.423-7.116-4.02-13.755-11.277-13.755H45.119Z\"></path></svg><defs><pattern id=\"_R_aldb_\" width=\"96\" height=\"480\" x=\"50%\" patternUnits=\"userSpaceOnUse\" patternTransform=\"translate(0 -96)\" fill=\"none\"><path d=\"M128 0 98.572 147.138A16 16 0 0 1 82.883 160H13.117a16 16 0 0 0-15.69 12.862l-26.855 134.276A16 16 0 0 1-45.117 320H-116M64-160 34.572-12.862A16 16 0 0 1 18.883 0h-69.766a16 16 0 0 0-15.69 12.862l-26.855 134.276A16 16 0 0 1-109.117 160H-180M192 160l-29.428 147.138A15.999 15.999 0 0 1 146.883 320H77.117a16 16 0 0 0-15.69 12.862L34.573 467.138A16 16 0 0 1 18.883 480H-52M-136 480h58.883a16 16 0 0 0 15.69-12.862l26.855-134.276A16 16 0 0 1-18.883 320h69.766a16 16 0 0 0 15.69-12.862l26.855-134.276A16 16 0 0 1 109.117 160H192M-72 640h58.883a16 16 0 0 0 15.69-12.862l26.855-134.276A16 16 0 0 1 45.117 480h69.766a15.999 15.999 0 0 0 15.689-12.862l26.856-134.276A15.999 15.999 0 0 1 173.117 320H256M-200 320h58.883a15.999 15.999 0 0 0 15.689-12.862l26.856-134.276A16 16 0 0 1-82.883 160h69.766a16 16 0 0 0 15.69-12.862L29.427 12.862A16 16 0 0 1 45.117 0H128\"></path></pattern></defs></svg><main id=\"main-content\" class=\"w-full flex-auto\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"Azure Web Store on Kubernetes — Part 1: Environment Setup & Docker Images\",\"description\":\"Setting up the Azure environment, building and testing Docker images for all microservices locally, and preparing for AKS deployment.\",\"datePublished\":\"2024-01-15\",\"url\":\"https://www.frankdoka.comundefined\",\"author\":{\"@type\":\"Person\",\"name\":\"Frank Doka\",\"url\":\"https://www.frankdoka.com\"}}</script><article class=\"mx-auto max-w-7xl px-6 lg:px-8 mt-24 sm:mt-32 lg:mt-40\" data-pagefind-body=\"true\"><div class=\"mx-auto max-w-2xl lg:max-w-none\"><div style=\"opacity:0;transform:translateY(24px)\"><header class=\"mx-auto flex max-w-5xl flex-col text-center\"><h1 class=\"mt-6 font-display text-5xl font-medium tracking-tight [text-wrap:balance] text-[var(--theme-text-primary)] sm:text-6xl\">Azure Web Store on Kubernetes — Part 1: Environment Setup &amp; Docker Images</h1><div class=\"order-first flex items-center justify-center gap-x-3 text-sm text-[var(--theme-text-secondary)]\"><time dateTime=\"2024-01-15\">January 15, 2024</time><span class=\"text-[var(--theme-text-muted)]\">·</span><span>1<!-- --> min read</span></div><p class=\"mt-6 text-sm font-semibold text-[var(--theme-text-secondary)]\">by <!-- -->Frank Doka</p><div class=\"mt-6 flex flex-wrap justify-center gap-2\"><a class=\"inline-flex items-center rounded-full border border-[var(--theme-border)] px-3 py-1 text-xs font-medium text-[var(--theme-text-secondary)] transition hover:border-[var(--theme-text-primary)] hover:bg-[var(--theme-text-primary)] hover:text-[var(--theme-bg-page)]\" href=\"/blog/tags/azure\">Azure</a><a class=\"inline-flex items-center rounded-full border border-[var(--theme-border)] px-3 py-1 text-xs font-medium text-[var(--theme-text-secondary)] transition hover:border-[var(--theme-text-primary)] hover:bg-[var(--theme-text-primary)] hover:text-[var(--theme-bg-page)]\" href=\"/blog/tags/kubernetes\">Kubernetes</a><a class=\"inline-flex items-center rounded-full border border-[var(--theme-border)] px-3 py-1 text-xs font-medium text-[var(--theme-text-secondary)] transition hover:border-[var(--theme-text-primary)] hover:bg-[var(--theme-text-primary)] hover:text-[var(--theme-bg-page)]\" href=\"/blog/tags/docker\">Docker</a></div></header></div><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"relative mt-24 sm:mt-32 lg:mt-40\"><div class=\"absolute -right-64 top-0 hidden w-56 xl:block\"></div><div class=\"*:mx-auto [&amp;&gt;:first-child]:mt-0! [&amp;&gt;:last-child]:mb-0!\"><div class=\"typography\">\n<!-- -->\n<!-- -->\n<h1 id=\"azure-web-store-on-kubernetes--part-1-environment-setup--docker-images\">Azure Web Store on Kubernetes — Part 1: Environment Setup &amp; Docker Images</h1>\n<p>Part 1 covers the foundation: setting up Azure resources and building Docker images for all four microservices before deploying to Kubernetes.</p>\n<h2 id=\"azure-resources\">Azure Resources</h2>\n<p>Deployed the initial Azure infrastructure:</p>\n<ul>\n<li><strong>Azure Container Registry</strong> — Private registry for storing Docker images</li>\n<li><strong>App Service + App Service Plan</strong> — Initial hosting target before migrating to AKS</li>\n<li><strong>AKS cluster</strong> — Managed Kubernetes for the final deployment</li>\n</ul>\n<h2 id=\"building-docker-images-locally\">Building Docker Images Locally</h2>\n<p>The microservices are pre-built Java Spring Boot applications. Before pushing anything to Azure, I built and tested all four images locally:</p>\n<div class=\"group relative\"><pre class=\"shiki nord\" style=\"background-color:#2e3440ff;color:#d8dee9ff\" tabindex=\"0\"><code><span class=\"line\"><span style=\"color:#616E88\"># Create a bridge network for inter-service communication</span></span>\n<span class=\"line\"><span style=\"color:#88C0D0\">docker</span><span style=\"color:#A3BE8C\"> network</span><span style=\"color:#A3BE8C\"> create</span><span style=\"color:#A3BE8C\"> webappbridge</span></span>\n<span class=\"line\"></span>\n<span class=\"line\"><span style=\"color:#616E88\"># Build and run each service</span></span>\n<span class=\"line\"><span style=\"color:#88C0D0\">docker</span><span style=\"color:#A3BE8C\"> build</span><span style=\"color:#A3BE8C\"> -t</span><span style=\"color:#A3BE8C\"> webappservice</span><span style=\"color:#A3BE8C\"> .</span></span>\n<span class=\"line\"><span style=\"color:#88C0D0\">docker</span><span style=\"color:#A3BE8C\"> run</span><span style=\"color:#A3BE8C\"> --rm</span><span style=\"color:#A3BE8C\"> --net</span><span style=\"color:#A3BE8C\"> webappbridge</span><span style=\"color:#A3BE8C\"> --name</span><span style=\"color:#A3BE8C\"> webappservice</span><span style=\"color:#EBCB8B\"> \\</span></span>\n<span class=\"line\"><span style=\"color:#A3BE8C\">  -p</span><span style=\"color:#A3BE8C\"> 8081:8081</span><span style=\"color:#A3BE8C\"> -e</span><span style=\"color:#A3BE8C\"> WEBAPPSERVICE_SERVER_PORT=</span><span style=\"color:#B48EAD\">8081</span><span style=\"color:#A3BE8C\"> -d</span><span style=\"color:#A3BE8C\"> webappservice:latest</span></span>\n<span class=\"line\"></span>\n<span class=\"line\"><span style=\"color:#616E88\"># Repeat for Product Service (8082) and Order Service (8083)</span></span></code></pre><button aria-label=\"Copy code\" class=\"absolute top-3 right-3 rounded-lg border border-[var(--theme-border)] bg-[var(--theme-bg-elevated)] p-1.5 text-[var(--theme-text-muted)] opacity-0 transition hover:bg-[var(--theme-bg-hover)] hover:text-[var(--theme-text-primary)] group-hover:opacity-100 focus:opacity-100\"><svg class=\"h-4 w-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z\"></path></svg></button></div>\n<p>Each service runs on its own port, communicates over the Docker bridge network, and responds correctly to API calls — confirmed with local testing before touching Azure.</p>\n<h2 id=\"whats-next\">What&#x27;s Next</h2>\n<p>Part 2 pushes images to Azure Container Registry, configures continuous deployment from ACR to App Service, and sets up the GitHub Actions CI/CD pipeline.</p>\n<!-- -->\n</div></div></div></div></div></article><div class=\"relative pt-12 sm:pt-16 lg:pt-20 mt-12 sm:mt-16 lg:mt-20\"><div class=\"absolute inset-x-0 top-0 -z-10 h-[884px] overflow-hidden rounded-t-4xl bg-linear-to-b from-[var(--theme-bg-elevated)]\"><svg aria-hidden=\"true\" class=\"absolute inset-0 h-full w-full [mask-image:linear-gradient(to_bottom_left,white_40%,transparent_50%)] fill-[var(--theme-bg-elevated)] stroke-[var(--theme-border-subtle)]\"><rect width=\"100%\" height=\"100%\" fill=\"url(#_R_tbsnpfeldb_)\" stroke-width=\"0\"></rect><svg x=\"50%\" y=\"-270\" stroke-width=\"0\" class=\"overflow-visible\"><path transform=\"translate(64 160)\" d=\"M45.119 4.5a11.5 11.5 0 0 0-11.277 9.245l-25.6 128C6.82 148.861 12.262 155.5 19.52 155.5h63.366a11.5 11.5 0 0 0 11.277-9.245l25.6-128c1.423-7.116-4.02-13.755-11.277-13.755H45.119Z\"></path><path transform=\"translate(128 320)\" d=\"M45.119 4.5a11.5 11.5 0 0 0-11.277 9.245l-25.6 128C6.82 148.861 12.262 155.5 19.52 155.5h63.366a11.5 11.5 0 0 0 11.277-9.245l25.6-128c1.423-7.116-4.02-13.755-11.277-13.755H45.119Z\"></path><path transform=\"translate(288 480)\" d=\"M45.119 4.5a11.5 11.5 0 0 0-11.277 9.245l-25.6 128C6.82 148.861 12.262 155.5 19.52 155.5h63.366a11.5 11.5 0 0 0 11.277-9.245l25.6-128c1.423-7.116-4.02-13.755-11.277-13.755H45.119Z\"></path><path transform=\"translate(512 320)\" d=\"M45.119 4.5a11.5 11.5 0 0 0-11.277 9.245l-25.6 128C6.82 148.861 12.262 155.5 19.52 155.5h63.366a11.5 11.5 0 0 0 11.277-9.245l25.6-128c1.423-7.116-4.02-13.755-11.277-13.755H45.119Z\"></path><path transform=\"translate(544 640)\" d=\"M45.119 4.5a11.5 11.5 0 0 0-11.277 9.245l-25.6 128C6.82 148.861 12.262 155.5 19.52 155.5h63.366a11.5 11.5 0 0 0 11.277-9.245l25.6-128c1.423-7.116-4.02-13.755-11.277-13.755H45.119Z\"></path><path transform=\"translate(320 800)\" d=\"M45.119 4.5a11.5 11.5 0 0 0-11.277 9.245l-25.6 128C6.82 148.861 12.262 155.5 19.52 155.5h63.366a11.5 11.5 0 0 0 11.277-9.245l25.6-128c1.423-7.116-4.02-13.755-11.277-13.755H45.119Z\"></path></svg><defs><pattern id=\"_R_tbsnpfeldb_\" width=\"96\" height=\"480\" x=\"50%\" patternUnits=\"userSpaceOnUse\" patternTransform=\"translate(0 -270)\" fill=\"none\"><path d=\"M128 0 98.572 147.138A16 16 0 0 1 82.883 160H13.117a16 16 0 0 0-15.69 12.862l-26.855 134.276A16 16 0 0 1-45.117 320H-116M64-160 34.572-