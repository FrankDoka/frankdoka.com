lor\":\"#ECEFF4\"},\"children\":\".\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#D8DEE9\"},\"children\":\"NEXT_PUBLIC_CF_ANALYTICS_TOKEN\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#ECEFF4\"},\"children\":\"}\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#A3BE8C\"},\"children\":\"\\\"}\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#ECEFF4\"},\"children\":\"`\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#81A1C1\"},\"children\":\"}\"}]]}],\"\\n\",[\"$\",\"span\",null,{\"className\":\"line\",\"children\":[\"$\",\"span\",null,{\"style\":{\"color\":\"#81A1C1\"},\"children\":\"  />\"}]}],\"\\n\",[\"$\",\"span\",null,{\"className\":\"line\",\"children\":[[\"$\",\"span\",null,{\"style\":{\"color\":\"#D8DEE9FF\"},\"children\":\")\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#ECEFF4\"},\"children\":\"}\"}]]}]]}]}]\n78:[\"$\",\"p\",null,{\"children\":[\"A \",[\"$\",\"code\",null,{\"children\":\"dns-prefetch\"}],\" and \",[\"$\",\"code\",null,{\"children\":\"preconnect\"}],\" hint for \",[\"$\",\"code\",null,{\"children\":\"static.cloudflareinsights.com\"}],\" in \",[\"$\",\"code\",null,{\"children\":\"<head>\"}],\" warms up the connection before the analytics script loads, shaving off connection setup time. No cookie banners needed. The token stays in environment config, not in source code.\"]}]\n79:[\"$\",\"h2\",null,{\"id\":\"performance\",\"children\":\"Performance\"}]\n7a:[\"$\",\"h3\",null,{\"id\":\"fontawesome-tree-shaking\",\"children\":\"FontAwesome Tree Shaking\"}]\n7b:[\"$\",\"p\",null,{\"children\":[\"The \",[\"$\",\"code\",null,{\"children\":\"optimizePackageImports\"}],\" config in \",[\"$\",\"code\",null,{\"children\":\"next.config.mjs\"}],\" tells the bundler to tree-shake at build time — only icons actually referenced in code make it into the bundle.\"]}]\n7c:[\"$\",\"h3\",null,{\"id\":\"static-generation\",\"children\":\"Static Generation\"}]\n7d:[\"$\",\"p\",null,{\"children\":\"The entire site pre-renders at build time — 60+ static HTML pages deployed to the CDN edge. No server-side rendering, no client-side data fetching for content. Time to first byte is just CDN latency.\"}]\n7e:[\"$\",\"h3\",null,{\"id\":\"image-strategy\",\"children\":\"Image Strategy\"}]\n7f:[\"$\",\"ul\",null,{\"children\":[\"\\n\",[\"$\",\"li\",null,{\"children\":\"Project illustrations are SVGs — infinitely scalable, tiny file sizes\"}],\"\\n\",[\"$\",\"li\",null,{\"children\":[\"Portrait photo uses Next.js \",[\"$\",\"code\",null,{\"children\":\"<Image>\"}],\" with responsive \",[\"$\",\"code\",null,{\"children\":\"sizes\"}],\", AVIF/WebP format conversion, and \",[\"$\",\"code\",null,{\"children\":\"placeholder=\\\"blur\\\"\"}],\" for instant low-res previews while the full image loads\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[\"Below-the-fold images use \",[\"$\",\"code\",null,{\"children\":\"loading=\\\"lazy\\\"\"}]]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"code\",null,{\"children\":\"@next/bundle-analyzer\"}],\" is available as a dev dependency — run \",[\"$\",\"code\",null,{\"children\":\"ANALYZE=true npm run build\"}],\" to visualize the bundle and catch bloat early\"]}],\"\\n\"]}]\n80:[\"$\",\"h2\",null,{\"id\":\"cloudflare-pages-deployment\",\"children\":\"Cloudflare Pages Deployment\"}]\n81:[\"$\",\"h3\",null,{\"id\":\"setup-steps\",\"children\":\"Setup Steps\"}]\n82:[\"$\",\"ol\",null,{\"children\":[\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Connect repo\"}],\" — Linked the GitHub repository to a new Cloudflare Pages project\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Build config\"}],\" — Build command: \",[\"$\",\"code\",null,{\"children\":\"npm run build && npx opennextjs-cloudflare\"}],\", output: \",[\"$\",\"code\",null,{\"children\":\".open-next/assets\"}]]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Custom domain\"}],\" — DNS was already on Cloudflare, so adding \",[\"$\",\"code\",null,{\"children\":\"frankdoka.com\"}],\" was a single click. SSL provisioned automatically\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Environment\"}],\" — Set \",[\"$\",\"code\",null,{\"children\":\"NODE_VERSION=22\"}],\" and \",[\"$\",\"code\",null,{\"children\":\"NEXT_PUBLIC_CF_ANALYTICS_TOKEN\"}],\" in build settings\"]}],\"\\n\"]}]\n83:[\"$\",\"h3\",null,{\"id\":\"cicd-flow\",\"children\":\"CI/CD Flow\"}]\n84:[\"$\",\"$L19\",null,{\"children\":[\"$\",\"code\",null,{\"children\":\"git push main → Cloudflare detects push → Build + Pagefind index → Deploy to edge\\nPull request  → Preview deployment at unique URL → Verify before merge\\n\"}]}]\n85:[\"$\",\"p\",null,{\"children\":[\"Every push to \",[\"$\",\"code\",null,{\"children\":\"main\"}],\" deploys to production. Pull requests get isolated preview URLs for verification.\"]}]\n86:[\"$\",\"h2\",null,{\"id\":\"end-to-end-testing\",\"children\":\"End-to-End Testing\"}]\n87:[\"$\",\"p\",null,{\"children\":\"Unit tests verify component logic, but they can't catch broken navigation, missing content, or integration issues between the server and client. Playwright handles this — it launches a real Chromium browser against a production build and tests the site the way a user would actually use it.\"}]\n88:[\"$\",\"p\",null,{\"children\":\"The test suite covers eight areas:\"}]\n89:[\"$\",\"$L19\",null,{\"children\":[\"$\",\"code\",null,{\"children\":\"src/test/e2e/\\n├── blog.spec.ts         # Blog listing, article links, post rendering\\n├── home.spec.ts         # Hero banner, sections, document title\\n├── links.spec.ts        # Social links, footer links, anchor targets\\n├── navigation.spec.ts   # Header nav, hamburger menu, footer nav, 404\\n├── projects.spec.ts     # Project listing, detail pages, status badges\\n├── responsive.spec.ts   # Mobile/desktop viewport, overflow, footer\\n├── search.spec.ts       # Search dialog, Ctrl+K shortcut, inline 404 search\\n└── theme.spec.ts        # Toggle, persistence across nav, reload, label\\n\"}]}]\n8a:[\"$\",\"p\",null,{\"children\":\"The Playwright config runs against a production build rather than the dev server — this catches issues that only surface with static generation, like missing data or hydration mismatches:\"}]\n8b:[\"$\",\"$L19\",null,{\"className\":\"shiki nord\",\"style\":{\"backgroundColor\":\"#2e3440ff\",\"color\":\"#d8dee9ff\"},\"tabIndex\":\"0\",\"children\":[\"$\",\"code\",null,{\"children\":[[\"$\",\"span\",null,{\"className\":\"line\",\"children\":[\"$\",\"span\",null,{\"style\":{\"color\":\"#616E88\"},\"children\":\"// playwright.config.ts\"}]}],\"\\n\",[\"$\",\"span\",null,{\"className\":\"line\",\"children\":[[\"$\",\"span\",null,{\"style\":{\"color\":\"#D8DEE9FF\"},\"children\":\"webServer\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#ECEFF4\"},\"children\":\":\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#ECEFF4\"},\"children\":\" {\"}]]}],\"\\n\",[\"$\",\"span\",null,{\"className\":\"line\",\"children\":[[\"$\",\"span\",null,{\"style\":{\"color\":\"#D8DEE9FF\"},\"children\":\"  command\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#ECEFF4\"},\"children\":\":\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#ECEFF4\"},\"children\":\" '\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#A3BE8C\"},\"children\":\"npm run build && npm start\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#ECEFF4\"},\"children\":\"'\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#ECEFF4\"},\"children\":\",\"}]]}],\"\\n\",[\"$\",\"span\",null,{\"className\":\"line\",\"children\":[[\"$\",\"span\",null,{\"style\":{\"color\":\"#D8DEE9FF\"},\"children\":\"  url\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#ECEFF4\"},\"children\":\":\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#ECEFF4\"},\"children\":\" '\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#A3BE8C\"},\"children\":\"http://localhost:3000\"}],[\"$\",\"span\",null,{\"style\":{\"color\":\"#ECEF