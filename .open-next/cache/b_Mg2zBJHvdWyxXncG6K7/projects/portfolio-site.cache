d-full bg-[var(--theme-bg-elevated)] px-4 py-1.5 text-base text-[var(--theme-text-secondary)] text-sm font-semibold text-[var(--theme-text-secondary)]\",\"children\":\"Next.js\"}]}],[\"$\",\"$L7\",\"1\",{\"children\":[\"$\",\"li\",null,{\"className\":\"rounded-full bg-[var(--theme-bg-elevated)] px-4 py-1.5 text-base text-[var(--theme-text-secondary)] text-sm font-semibold text-[var(--theme-text-secondary)]\",\"children\":\"Tailwind CSS\"}]}],[\"$\",\"$L7\",\"2\",{\"children\":[\"$\",\"li\",null,{\"className\":\"rounded-full bg-[var(--theme-bg-elevated)] px-4 py-1.5 text-base text-[var(--theme-text-secondary)] text-sm font-semibold text-[var(--theme-text-secondary)]\",\"children\":\"MDX\"}]}],[\"$\",\"$L7\",\"3\",{\"children\":[\"$\",\"li\",null,{\"className\":\"rounded-full bg-[var(--theme-bg-elevated)] px-4 py-1.5 text-base text-[var(--theme-text-secondary)] text-sm font-semibold text-[var(--theme-text-secondary)]\",\"children\":\"TypeScript\"}]}],[\"$\",\"$L7\",\"4\",{\"children\":[\"$\",\"li\",null,{\"className\":\"rounded-full bg-[var(--theme-bg-elevated)] px-4 py-1.5 text-base text-[var(--theme-text-secondary)] text-sm font-semibold text-[var(--theme-text-secondary)]\",\"children\":\"Cloudflare Pages\"}]}],[\"$\",\"$L7\",\"5\",{\"children\":[\"$\",\"li\",null,{\"className\":\"rounded-full bg-[var(--theme-bg-elevated)] px-4 py-1.5 text-base text-[var(--theme-text-secondary)] text-sm font-semibold text-[var(--theme-text-secondary)]\",\"children\":\"Pagefind\"}]}],[\"$\",\"$L7\",\"6\",{\"children\":[\"$\",\"li\",null,{\"className\":\"rounded-full bg-[var(--theme-bg-elevated)] px-4 py-1.5 text-base text-[var(--theme-text-secondary)] text-sm font-semibold text-[var(--theme-text-secondary)]\",\"children\":\"Zod\"}]}]]}]}]}]}],[\"$\",\"$L7\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"mt-6 pt-6 relative before:absolute after:absolute before:bg-[var(--theme-text-muted)] after:bg-[var(--theme-border-subtle)] before:top-0 before:left-0 before:h-px before:w-6 after:top-0 after:right-0 after:left-8 after:h-px\",\"children\":[\"$\",\"div\",null,{\"className\":\"typography\",\"children\":[\"\\n\",\"\\n\",\"\\n\",[\"$\",\"h2\",null,{\"id\":\"overview\",\"children\":\"Overview\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":[\"The original \",[\"$\",\"a\",null,{\"href\":\"/projects/cloud-resume-challenge\",\"children\":\"Cloud Resume Challenge\"}],\" site was a static HTML resume on S3 and CloudFront. It demonstrated serverless architecture, but it was a single page — no room for project write-ups, build logs, or anything beyond a resume. This project replaced it with a production portfolio built for long-term use, then modernized it with search, validation, and developer experience features.\"]}],\"\\n\",[\"$\",\"h2\",null,{\"id\":\"architecture\",\"children\":\"Architecture\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"The site runs on four layers:\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Content pipeline\"}],\" — Blog posts and project pages are authored in MDX. At build time, Zod schemas validate every metadata export (titles, dates, tags, status fields), catching errors before they reach production. A remark/rehype plugin chain then transforms the content: GitHub Flavored Markdown, automatic layout wrapping, heading ID generation via \",[\"$\",\"code\",null,{\"children\":\"rehypeSlug\"}],\", Shiki syntax highlighting, and image unwrapping. A loader function discovers all MDX files with \",[\"$\",\"code\",null,{\"children\":\"fast-glob\"}],\", validates metadata, and sorts entries by date.\"]}],\"\\n\",[\"$\",\"p\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Application layer\"}],\" — Next.js 15 with the App Router handles routing, static generation, and React Server Components. Tailwind CSS v4 provides utility-first styling through CSS-native configuration. Framer Motion adds scroll-triggered animations, and the View Transitions API provides smooth page-to-page transitions natively in the browser. The entire site is TypeScript with Zod runtime validation.\"]}],\"\\n\",\"$L1b\",\"\\n\",\"$L1c\",\"\\n\",\"$L1d\",\"\\n\",\"$L1e\",\"\\n\",\"$L1f\",\"\\n\",\"$L20\",\"\\n\",\"$L21\",\"\\n\",\"$L22\",\"\\n\",\"\\n\"]}]}]}]]}]\n19:[\"$\",\"div\",null,{\"className\":\"relative pt-12 sm:pt-16 lg:pt-20 mt-24 sm:mt-32 lg:mt-40\",\"children\":[[\"$\",\"div\",null,{\"className\":\"absolute inset-x-0 top-0 -z-10 h-[884px] overflow-hidden rounded-t-4xl bg-linear-to-b from-[var(--theme-bg-elevated)]\",\"children\":[\"$\",\"$L23\",null,{\"className\":\"absolute inset-0 h-full w-full [mask-image:linear-gradient(to_bottom_left,white_40%,transparent_50%)] fill-[var(--theme-bg-elevated)] stroke-[var(--theme-border-subtle)]\",\"yOffset\":-270}]}],[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-7xl px-6 lg:px-8\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-2xl lg:max-w-none\",\"children\":[\"$\",\"$L7\",null,{\"className\":\"max-w-2xl\",\"children\":[[\"$\",\"h2\",null,{\"children\":[\"$undefined\",[\"$\",\"span\",null,{\"className\":\"block font-display tracking-tight text-[var(--theme-text-primary)] [text-wrap:balance] text-2xl font-semibold\",\"children\":\"More projects\"}]]}],\"$undefined\"]}]}]}],[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-7xl px-6 lg:px-8 mt-16\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-2xl lg:max-w-none\",\"children\":[\"$\",\"$L1a\",null,{\"className\":\"grid grid-cols-1 gap-x-8 gap-y-16 lg:grid-cols-2\",\"children\":[[\"$\",\"$L7\",\"/projects/azure-kubernetes-store\",{\"children\":[[\"$\",\"article\",\"/projects/azure-kubernetes-store\",{\"children\":[\"$\",\"div\",null,{\"className\":\"relative flex flex-col items-start pl-8 relative before:absolute after:absolute before:bg-[var(--theme-text-muted)] after:bg-[var(--theme-border-subtle)] before:top-0 before:left-0 before:h-6 before:w-px after:top-8 after:bottom-0 after:left-0 after:w-px\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"mt-6 text-base font-semibold text-[var(--theme-text-primary)]\",\"children\":\"Azure Web Store on Kubernetes\"}],[\"$\",\"time\",null,{\"dateTime\":\"2024\",\"className\":\"order-first text-sm text-[var(--theme-text-secondary)]\",\"children\":\"2024\"}],[\"$\",\"p\",null,{\"className\":\"mt-2.5 text-base text-[var(--theme-text-secondary)]\",\"children\":\"Microservices web store on AKS — Java Spring Boot services, Azure B2C identity, API Management gateway, and GitHub Actions CI/CD.\"}],[\"$\",\"$L9\",null,{\"href\":\"/projects/azure-kubernetes-store\",\"className\":\"mt-6 flex gap-x-3 text-base font-semibold text-[var(--theme-text-primary)] transition hover:text-[var(--theme-text-secondary)]\",\"aria-label\":\"Read more: Azure Web Store on Kubernetes\",\"children\":[\"Read more\",[\"$\",\"svg\",null,{\"viewBox\":\"0 0 24 6\",\"aria-hidden\":\"true\",\"className\":\"w-6 flex-none fill-current\",\"children\":[\"$\",\"path\",null,{\"fillRule\":\"evenodd\",\"clipRule\":\"evenodd\",\"d\":\"M24 3 18 .5v2H0v1h18v2L24 3Z\"}]}],[\"$\",\"span\",null,{\"className\":\"absolute inset-0\"}]]}]]}]}]]}],[\"$\",\"$L7\",\"/projects/text-to-speech\",{\"children\":[[\"$\",\"article\",\"/projects/text-to-speech\",{\"children\":[\"$\",\"div\",null,{\"className\":\"relative flex flex-col items-start pl-8 relative before:absolute after:absolute before:bg-[var(--theme-text-muted)] after:bg-[var(--theme-border-subtle)] before:top-0 before:left-0 before:h-6 before:w-px after:top-8 after:bottom-0 after:left-0 after:w-px\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"mt-6 text-base font-semibold text-[var(--theme-text-primary)]\",\"children\":\"Text-to-Speech Serverless App\"}],[\"$\",\"time\",null,{\"dateTime\":\"2023\",\"className\":\"order-first text-sm text-[var(--theme-text-secondary)]\",\"children\":\"2023\"}],[\"$\",\"p\",null,{\"className\":\"mt-2.5 text-base text-[var(--theme-text-secondary)]\",\"children\":\"Serverless multilingual text-to-speech app on AWS — Cognito auth, Lambda processing pipeline, Polly synthesis, and Terraform IaC.\"}],[\"$\",\"$L9\",null,{\"href\":\"/projects/text-to-speech\",\"className\":\"mt-6 flex gap-x-3 text-base font-semibold text-[var(--theme-text-primary)] transition hover:text-[var(--theme-text-secondary)]\",\"aria-label\":\"Read more: Text-to-Speech Serverless App\",\"children\":[\"Read more\",[\"$\",\"svg\",null,{\"viewBox\":\"0 0 24 6\",\"aria-hidden\":\"true\",\"className\":\"w-6 flex-none fill-current\",\"children\":\"$L24\"}],\"$L25\"]}]]}]}]]}]]}]}]}]]}]\n1b:[\"$\",\"p\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Features layer\"}],\" — Pagefind provides static full-text search with a keyboard-accessible dialog (Ctrl/Cmd+K). Blog posts get auto-generated table of contents from headings, reading time estimates, and dynamic Open Graph images for social sharing. An RSS 2.0 feed serves blog content to feed readers. Cloudflare Web Analytics tracks usage without cookies.\"]}]\n1c:[\"$\",\"p\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Deployment\"}],\" — GitHub pushes trigger Cloudflare Pages builds. The site pre-renders 60+ static HTML pages, Pagefind indexes them for search, and everything deploys to Cloudflare's edge network.\"]}]\n1d:[\"$\",\"h2\",null,{\"id\":\"what-i-built\",\"children\":\"What I Built\"}]\n1e:[\"$\",\"ul\",null,{\"children\":[\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Homepage\"}],\" with hero banner, about section, latest blog posts, and featured project cards\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Project pages\"}],\" with architecture diagrams, technical breakdowns, and linked build log series\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Blog system\"}],\" with MDX, syntax highlighting, reading time, table of contents, and tag-based filtering\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Static search\"}],\" — Pagefind indexes all pages at build time with \",[\"$\",\"code\",null,{\"children\":\"data-pagefind-body\"}],\" scoping, modal search dialog, keyboard shortcut, and inline search on the 404 page for dead link recovery\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Dark/light theme\"}],\" — Toggle with localStorage persistence and system preference detection, no flash of wrong theme\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"RSS feed\"}],\" — Full blog content (not just descriptions) served at \",[\"$\",\"code\",null,{\"children\":\"/feed.xml\"}],\" via \",[\"$\",\"code\",null,{\"children\":\"content:encoded\"}],\" for feed readers\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Dynamic OG images\"}],\" — Auto-generated social preview images per blog post and project using \",[\"$\",\"code\",null,{\"children\":\"next/og\"}]]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Copy-to-clipboard\"}],\" — One-click code copying on every code block across the site\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"MDX callout components\"}],\" — Reusable info, warning, danger, and tip boxes for rich blog content\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"PWA support\"}],\" — Service worker for offline access, installable as a homescreen app\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Experience section\"}],\" with structured job data, detail pages, and skill grids\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"About page\"}],\" with certifications, education, and professional values\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Toolbox page\"}],\" showcasing tools and technologies\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Full SEO\"}],\" — JSON-LD structured data, dynamic sitemap, Open Graph images, web app manifest\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Security headers\"}],\" — Content Security Policy, X-Frame-Options, Referrer-Policy, Permissions-Policy\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Accessibility\"}],\" — Skip-to-main link, focus-visible outlines, semantic HTML landmarks, external link handling\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Schema validation\"}],\" — Zod validates all MDX metadata at build time, catching missing or malformed fields early\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Image optimization\"}],\" — Blur placeholders on raster images, AVIF/WebP format negotiation, responsive \",[\"$\",\"code\",null,{\"children\":\"sizes\"}]]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Bundle analysis\"}],\" — \",[\"$\",\"code\",null,{\"children\":\"@next/bundle-analyzer\"}],\" for monitoring JS bundle size\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Performance hints\"}],\" — DNS prefetch and preconnect for third-party scripts\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"E2E testing\"}],\" — 55 Playwright tests covering navigation, search, theme toggle, responsive layout, and link integrity\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Lighthouse CI\"}],\" — Automated performance, accessibility, SEO, and best-practices audits on every pull request\"]}],\"\\n\"]}]\n1f:[\"$\",\"h2\",null,{\"id\":\"key-decisions\",\"children\":\"Key Decisions\"}]\n20:[\"$\",\"div\",null,{\"className\":\"my-10 max-sm:-mx-6 max-sm:flex max-sm:overflow-x-auto\",\"children\":[\