\",null,{\"className\":\"typography\",\"children\":[\"\\n\",\"\\n\",\"\\n\",[\"$\",\"h2\",null,{\"id\":\"what-i-built\",\"children\":\"What I Built\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"A full-stack serverless application that translates text into any supported language and synthesizes it as spoken audio — secured with Cognito, processed asynchronously, and deployed entirely with Terraform.\"}],\"\\n\",[\"$\",\"ol\",null,{\"children\":[\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"React frontend\"}],\" hosted on Amplify with Cognito sign-up/sign-in and JWT-based API authorization.\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Submission pipeline\"}],\" — API Gateway receives text, Lambda writes to DynamoDB and publishes to SNS for async processing.\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Processing pipeline\"}],\" — A second Lambda translates the text via Amazon Translate, synthesizes speech with Polly, and stores the audio in S3.\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Retrieval\"}],\" — The frontend polls a third Lambda to fetch the completed audio file URL from DynamoDB.\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Infrastructure as Code\"}],\" — Every resource defined in Terraform.\"]}],\"\\n\"]}],\"\\n\",[\"$\",\"h2\",null,{\"id\":\"architecture\",\"children\":\"Architecture\"}],\"\\n\",[\"$\",\"$L25\",null,{\"children\":[\"$\",\"code\",null,{\"children\":\"User → React (Amplify) → Cognito Auth → API Gateway → Lambda (submit)\\n                                                           ↓\\n                                                      DynamoDB + SNS\\n                                                           ↓\\n                                              Lambda (process: Translate + Polly)\\n                                                           ↓\\n                                                      S3 (audio) + DynamoDB (update)\\n                                                           ↓\\n                                              Lambda (retrieve) → React UI\\n\"}]}],\"\\n\",[\"$\",\"h2\",null,{\"id\":\"read-more\",\"children\":\"Read More\"}],\"\\n\",[\"$\",\"ul\",null,{\"children\":[\"\\n\",[\"$\",\"li\",null,{\"children\":[\"$\",\"a\",null,{\"href\":\"/blog/text-to-speech-1\",\"children\":\"Phase 1: Frontend & Login System\"}]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[\"$\",\"a\",null,{\"href\":\"/blog/text-to-speech-2\",\"children\":\"Phase 2: Serverless Backend & Data Storage\"}]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[\"$\",\"a\",null,{\"href\":\"/blog/text-to-speech-3\",\"children\":\"Phase 3: AWS Polly, Translate & S3 Storage\"}]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[\"$\",\"a\",null,{\"href\":\"/blog/text-to-speech-4\",\"children\":\"Phase 4: Frontend Integration & Retrieval\"}]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[\"$\",\"a\",null,{\"href\":\"/blog/text-to-speech-5\",\"children\":\"Phase 5: Infrastructure as Code with Terraform\"}]}],\"\\n\"]}],\"\\n\",\"\\n\"]}]}]}]\n24:[\"$\",\"div\",null,{\"className\":\"relative pt-12 sm:pt-16 lg:pt-20 mt-24 sm:mt-32 lg:mt-40\",\"children\":[[\"$\",\"div\",null,{\"className\":\"absolute inset-x-0 top-0 -z-10 h-[884px] overflow-hidden rounded-t-4xl bg-linear-to-b from-[var(--theme-bg-elevated)]\",\"children\":[\"$\",\"$L26\",null,{\"className\":\"absolute inset-0 h-full w-full [mask-image:linear-gradient(to_bottom_left,white_40%,transparent_50%)] fill-[var(--theme-bg-elevated)] stroke-[var(--theme-border-subtle)]\",\"yOffset\":-270}]}],[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-7xl px-6 lg:px-8\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-2xl lg:max-w-none\",\"children\":[\"$\",\"$L7\",null,{\"className\":\"max-w-2xl\",\"children\":[[\"$\",\"h2\",null,{\"children\":[\"$undefined\",[\"$\",\